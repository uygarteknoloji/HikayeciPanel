  q := TUniQuery.Create(nil);
  try
    try
      q.Close;
      q.Connection := UniServerModule.Data;
      q.KeyFields := 'LIS_ID';
      q.SpecificOptions.Values['KeyGenerator'] := 'GEN_LISTELER_ID';
