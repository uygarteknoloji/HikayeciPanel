procedure TMainForm.btnGirisClick(Sender: TObject);
var
  LoginForm: TLoginForm;
  SonTarih: TDateTime;
  Bugun: TDateTime;
  KalanGun: Integer;
  btnKullanicilar: TUniToolButton;
begin
  LoginForm := TLoginForm.Create(UniApplication);
  LoginForm.ShowModal(
    procedure(Sender: TComponent; AResult: Integer)
    begin
      if AResult = mrOk then
      begin
        if UniMainModule.isLogin then
        begin
          Bugun := Date;
          SonTarih := UniMainModule.KUL_BITTARIHI;
          KalanGun := Trunc(SonTarih - Bugun);
          UniStatusBar1.Panels[0].Text := 'Hoţgeldiniz Sayýn, ' + UniMainModule.KUL_ADI_SOYADI;
          if KalanGun > 0 then
            UniStatusBar1.Panels[0].Text := UniStatusBar1.Panels[0].Text + ', ' + Format('Aboneliđinizin bitmesine %d gün kaldý.', [KalanGun])
          else if KalanGun = 0 then
            UniStatusBar1.Panels[0].Text := UniStatusBar1.Panels[0].Text + ', ' + 'Aboneliđiniz bugün sona eriyor!'
          else begin
            UniMainModule.Notification('', 'Abonelik süreniz dolmuţtur. Lütfen aboneliđinizi yenileyiniz', 1);
            exit;
          end;
          if UniMainModule.KUL_ROLU='Sistem Yöneticisi' then
          begin
            btnKullanicilar := TUniToolButton.Create(UniToolBar1);
            btnKullanicilar.Parent := UniToolBar1;
            btnKullanicilar.OnClick := KullanicilarClick;
            btnKullanicilar.ImageIndex := 6;
            btnKullanicilar.Hint := 'Kullanýcýlar';
            btnKullanicilar.ShowHint := true;
            btnKullanicilar.ScreenMask.Enabled := true;
            btnKullanicilar.ScreenMask.Target := MainForm;
          end;
          try
            qDuyurular.Close;
            qDuyurular.Open;
            UniMainModule.Duyurular := '';
            UniStatusBar1.Panels[1].Text := '';
            while not qDuyurular.Eof do
            begin
              UniMainModule.Duyurular := UniMainModule.Duyurular + qDuyurular.FieldByName('DYR_KONU').AsString + ', ';
              qDuyurular.Next;
            end;
            if UniMainModule.Duyurular<>'' then
            begin
              UniStatusBar1.Panels[1].Text := UniMainModule.Duyurular;
              UniTimer1.Enabled := True;
            end;
          except on e:exception do
            UniMainModule.Notification('', HataMesaj(e.Message), 2);
          end;
          pnlGiris.Hide;
        end;
      end
      else if AResult = mrCancel then
      begin
        UniMainModule.isLogin := false;
      end;
    end
  );
end;

procedure TMainForm.KullanicilarClick(Sender: TObject);
var
  T: TUniTabSheet;
  KullanicilarForm: TKullanicilarForm;
begin
  if not UniMainModule.isLogin then
  begin
    UniMainModule.Notification('', 'Kullanýcý giriţi yapmalýsýnýz', 2);
    Exit;
  end;
  try
    TabNo := TabNo + 1;
    T := TUniTabSheet.Create(Self);
    T.Name := 'TS' + IntToStr(tabno);
    T.PageControl := UniPageControl1;
    T.Closable := True;
    T.Caption := 'Kullanýcýlar';
    UniPageControl1.ActivePage := T;
    KullanicilarForm := TKullanicilarForm.Create(T);
    KullanicilarForm.Align := alClient;
    KullanicilarForm.Parent := T;
    KullanicilarForm.Show;
  except on e: exception do
    begin
     UniMainModule.Notification('', HataMesaj(e.Message), 2);
    end;
  end;

end;

procedure TMainForm.GetThemes;
var
  S : TUniStringArray;
  I : Integer;
  M : TUniMenuItem;
begin
  S := UniServerModule.ThemeManager.AllThemes;

  UniThemePopup.Items.Clear;
  for I := Low(S) to High(S) do
  begin
    M := TUniMenuItem.Create(Self);
    M.Caption := S[I];
    M.Checked := SameText(M.Caption, UniMainModule.Theme);
    M.OnClick := ThemeClick;
    UniThemePopup.Items.Add(M);
  end;
end;

procedure TMainForm.ThemeClick(Sender: TObject);
var
  S : string;
begin
  S := UniSession.UrlReferer;
  if Pos('xtheme', S) > 0 then
  begin
    S := StringReplace(S, 'xtheme=', 'nnn=', []); // remove theme from current URL
    UniSession.UrlReferer := S;
  end;

  UniMainModule.Theme := (Sender as TUniMenuItem).Caption;
end;

