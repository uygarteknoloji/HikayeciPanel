unit Cihazlar;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Kullanici,
  Controls, Forms, uniGUITypes, uniGUIAbstractClasses, StrUtils, UniPageControl,
  uniGUIClasses, uniGUIFrame, Data.DB, MemDS, DBAccess, Uni, uniBasicGrid,
  uniGUIBaseClasses, uniSweetAlert, uniDBGrid, uniMultiItem, Dosya,
  uniComboBox, uniEdit, uniButton, uniBitBtn, uniPanel;

type
  TCihazlarForm = class(TUniFrame)
    UniPanel1: TUniPanel;
    UniToolBar1: TUniPanel;
    btnYeni: TUniBitBtn;
    btnDegistir: TUniBitBtn;
    btnSil: TUniBitBtn;
    btnKapat: TUniBitBtn;
    UniPanel2: TUniPanel;
    btnSec: TUniBitBtn;
    pnlBul: TUniPanel;
    UniPanel3: TUniPanel;
    btnBul: TUniBitBtn;
    txtCihaz: TUniEdit;
    txtDurum: TUniComboBox;
    txtKayitSayisi: TUniComboBox;
    Grid: TUniDBGrid;
    dsCihazlar: TDataSource;
    sil: TUniSweetAlert;
    qCihazlar: TUniQuery;
    procedure btnBulClick(Sender: TObject);
    procedure btnKapatClick(Sender: TObject);
    procedure btnSecClick(Sender: TObject);
    procedure btnSilClick(Sender: TObject);
    procedure GridAjaxEvent(Sender: TComponent; EventName: string;
      Params: TUniStrings);
    procedure GridColumnSort(Column: TUniDBGridColumn; Direction: Boolean);
    procedure GridDblClick(Sender: TObject);
    procedure btnDegistirClick(Sender: TObject);
    procedure GridDrawColumnCell(Sender: TObject; ACol, ARow: Integer;
      Column: TUniDBGridColumn; Attribs: TUniCellAttribs);
    procedure silConfirm(Sender: TObject);
    procedure UniFrameAjaxEvent(Sender: TComponent; EventName: string;
      Params: TUniStrings);
    procedure UniFrameCreate(Sender: TObject);
    procedure btnYeniClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
    PDosyaForm: TDosyaForm;
  end;

implementation

{$R *.dfm}

uses ServerModule, MainModule, Utils, Cihaz;

procedure TCihazlarForm.btnBulClick(Sender: TObject);
begin
  try
    qCihazlar.Close;
    qCihazlar.Conditions.Clear;
    pnlBul.Caption := '';
    Grid.WebOptions.PageSize := StrToInt(txtKayitSayisi.Text);
    if txtDurum.ItemIndex=0 then
    begin
      qCihazlar.Conditions.Add('DURUM', 'CIH_DURUM=1', True);
      pnlBul.Caption := pnlBul.Caption + ifthen(pnlBul.Caption <> '', ', ') + 'Durum : Kullanýmda';
    end
    else
    if txtDurum.ItemIndex=1 then
    begin
      qCihazlar.Conditions.Add('DURUM', 'CIH_DURUM=0', True);
      pnlBul.Caption := pnlBul.Caption + ifthen(pnlBul.Caption <> '', ', ') + 'Durum : Kullaným Dýţý';
    end;
    if txtCihaz.Text<>'' then
    begin
      qCihazlar.Conditions.Add('KOD', 'UPPER(CIH_ADI) LIKE ''' + Buyuk(SuzgecVerisiIsle(txtCihaz.Text)) + '''', True);
      pnlBul.Caption := pnlBul.Caption + ifthen(pnlBul.Caption <> '', ', ') + 'Cihaz : ' + SuzgecVerisiIsle(txtCihaz.Text);
    end;

    qCihazlar.Conditions.Enable;
    qCihazlar.Open;
    pnlBul.Visible := pnlBul.Caption <> '';

    UniMainModule.Focus(Grid);
  except on e:exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TCihazlarForm.btnDegistirClick(Sender: TObject);
var
  I: Integer;
  T: TUniTabSheet;
  F: TCihazForm;
begin
  try
    if qCihazlar.IsEmpty then exit;
    if isFrameOpenedInTab('TCihazForm', TUniTabSheet(Self.Parent)) then exit;

    UniMainModule.Tmp_ID := qCihazlar.FieldByName('CIH_ID').AsInteger;

    T := TUniTabSheet(Self.Parent);
    T.Caption := T.Caption + ' > Cihaz [' + qCihazlar.FieldByName('CIH_ADI').AsString + ']';

    for I := 0 to T.ControlCount-1 do
      T.Controls[I].Visible := False;

    F := TCihazForm.Create(T);
    F.UniPanel1.Caption :=  'Cihaz [' + qCihazlar.FieldByName('CIH_ADI').AsString + ']';
    F.PCihazlarForm := Self;
    F.Align := alClient;
    F.Parent := T;
    F.Show;
  except on E: Exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TCihazlarForm.btnKapatClick(Sender: TObject);
begin
  UniMainModule.FrameKapat(Self);
end;

procedure TCihazlarForm.btnSecClick(Sender: TObject);
begin
  try
    UniMainModule.FrameKapat(Self);
  except on E: Exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TCihazlarForm.btnSilClick(Sender: TObject);
begin
  try
    if qCihazlar.IsEmpty then exit;
    sil.Show();
  except on e:exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;

end;

procedure TCihazlarForm.btnYeniClick(Sender: TObject);
var
  I: Integer;
  T: TUniTabSheet;
  F: TCihazForm;
begin
  try
    if isFrameOpenedInTab('TCihazForm', TUniTabSheet(Self.Parent)) then exit;
    UniMainModule.Tmp_ID := 0;

    T := TUniTabSheet(Self.Parent);
    T.Caption := T.Caption + ' > Cihaz [Yeni]';

    for I := 0 to T.ControlCount-1 do
      T.Controls[I].Visible := False;

    F := TCihazForm.Create(T);
    F.UniPanel1.Caption := 'Cihaz [Yeni]';
    F.PCihazlarForm := Self;
    F.Align := alClient;
    F.Parent := T;
    F.Show;
  except on E: Exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TCihazlarForm.GridAjaxEvent(Sender: TComponent; EventName: string;
  Params: TUniStrings);
begin
  if EventName='kaydet' then
    UniMainModule.ListeKaydet(1, 'Cihazlar', qCihazlar, Grid)
  else
  if EventName='sil' then
    UniMainModule.ListeVarsayilan(20);
end;

procedure TCihazlarForm.GridColumnSort(Column: TUniDBGridColumn;
  Direction: Boolean);
begin
  UniMainModule.Sort(qCihazlar, Column.FieldName, Direction);
end;

procedure TCihazlarForm.GridDblClick(Sender: TObject);
begin
  if btnSec.Visible = true then
    btnSecClick(btnSec)
  else
    btnDegistirClick(btnDegistir);
end;

procedure TCihazlarForm.GridDrawColumnCell(Sender: TObject; ACol,
  ARow: Integer; Column: TUniDBGridColumn; Attribs: TUniCellAttribs);
begin
  if Column.FieldName='CIH_DURUM' then
    if Column.Field.IsNull = false then
      if Column.Field.AsInteger = 0 then
      begin
        Attribs.Color := clRed;
        Attribs.Font.Color := clWhite;
      end;
end;

procedure TCihazlarForm.silConfirm(Sender: TObject);
begin
  try
    qCihazlar.Delete;
    UniMainModule.Notification('', 'Kayýt Silindi', 3);
    UniMainModule.Focus(txtCihaz);
  except on e:exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TCihazlarForm.UniFrameAjaxEvent(Sender: TComponent;
  EventName: string; Params: TUniStrings);
begin
  if EventName = 'esc_pressed' then btnKapatClick(Sender);
end;

procedure TCihazlarForm.UniFrameCreate(Sender: TObject);
begin
  Grid.ClientEvents.ExtEvents.Values['viewready'] := 'function (sender, eOpts)' +
       '{' +
       'var tm = new Ext.util.TextMetrics();' +
       'sender.view.tip = Ext.create("Ext.tip.ToolTip", {' +
       'target: sender.view.el,' +
       'delegate: sender.view.cellSelector,' +
       'trackMouse: true,' +
       'renderTo: Ext.getBody(),' +
       'listeners: {' +
       'beforeshow: function updateTipBody(tip) {' +
       'gridColums = sender.view.getGridColumns();' +
       'column = gridColums[tip.triggerElement.cellIndex];' +
       'record = sender.view.getRecord(tip.triggerElement.parentNode);' +
       'if (column.dataIndex !== "-1" && (column.getWidth() < (tm.getSize(record.data[parseInt(column.dataIndex)]).width) + 5)) {' +
       'tip.update(record.data[parseInt(column.dataIndex)]);' +
       '} else {' +
       'return false;' +
       '}' +
       '}' +
       '}' +
       '});' +
       '}';

  Grid.ClientEvents.UniEvents.Values['pagingBar.afterCreate'] := 'function (sender){' +
         'sender.dock = "top";' +
         'sender.displayMsg = "Kayýt Adedi : {2}";' +
         'sender.displayInfo = true;' +
         'sender.insert(0, [{' +
         'xtype: "label",' +
         'cls: "grdfooter",' +
         'padding: "0 0 1 5"' +
         '},' +

         '{' +
         'xtype: "button",' +
         'icon: "files/img/ok.png",' +
         'tooltip: "Liste Görünümünü Kaydet",' +
         'handler: function() {' +
         'ajaxRequest(sender, "kaydet", []);' +
         '}' +
         '},' +

         '{' +
         'xtype: "tbseparator"' +
         '},' +

         '{' +
         'xtype: "button",' +
         'icon: "files/img/delete.png",' +
         'tooltip: "Varsayýlan Görünüm",' +
         'handler: function() {' +
         'ajaxRequest(sender, "sil", []);' +
         '}' +
         '},' +

         '{' +
         'xtype: "tbseparator"' +
         '}' +

         ']);' +
         '}';

  self.ClientEvents.ExtEvents.Values['afterrender'] := 'function afterrender(sender, eOpts)' +
         '{' +
         '   sender.el.on("keydown", function(e){' +
         '   if (e.getKey() == Ext.EventObject.ESC) {' +
         '      ajaxRequest(sender, "esc_pressed", []);' +
         '   }' +
         '   });' +
         '}';

//  else
//    Grid.ClientEvents.UniEvents.Values['pagingBar.afterCreate'] := 'function (sender){ sender.dock = "top"; }';

  UniMainModule.ButtonMask([btnYeni, btnDegistir, btnBul, btnSec, btnKapat]);
  UniMainModule.SetFocusBlur(TUniFrame(Self));

  try
    if qCihazlar.Active then
      qCihazlar.Close;
    qCihazlar.Open;

    UniMainModule.ListeYukle(2, Grid);
    if UniMainModule.Tmp_Form_Sec = 1 then
    begin
      UniMainModule.Tmp_Form_Sec := -1;
      btnSec.Visible := true;
      Grid.OnDblClick := btnSecClick;
    end;
    if UniMainModule.Tmp_Kod<>'' then
    begin
      txtCihaz.Text := UniMainModule.Tmp_Kod;
      UniMainModule.Tmp_Kod := '';
      btnBulClick(btnBul);
    end;
    UniMainModule.Focus(txtCihaz);

  except on e: exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

end.
