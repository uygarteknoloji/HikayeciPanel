unit Dosya;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, UniPageControl,
  Controls, Forms, uniGUITypes, uniGUIAbstractClasses, Dosyalar,
  uniGUIClasses, uniGUIFrame, Data.DB, MemDS, DBAccess, Uni, uniGUIBaseClasses,
  uniSweetAlert, uniMultiItem, uniComboBox, uniDBComboBox, uniDBLookupComboBox,
  uniCheckBox, uniDBCheckBox, uniMemo, uniDBMemo, uniEdit, uniDBEdit,
  uniScrollBox, uniButton, uniBitBtn, uniPanel, uniImage, uniDBImage, Vcl.Menus,
  uniMainMenu, uniFileUpload;

type
  TDosyaForm = class(TUniFrame)
    UniToolBar1: TUniPanel;
    btnKaydet: TUniBitBtn;
    UniPanel1: TUniPanel;
    btnYeni: TUniBitBtn;
    btnKapat: TUniBitBtn;
    btnVazgec: TUniBitBtn;
    btnSil: TUniBitBtn;
    btnYardim: TUniBitBtn;
    UniScrollBox1: TUniScrollBox;
    txtYazarAdi: TUniDBEdit;
    txtDurum: TUniDBCheckBox;
    txtDosyaAdi: TUniDBEdit;
    sil: TUniSweetAlert;
    iptal: TUniSweetAlert;
    qDosya: TUniQuery;
    dsDosya: TDataSource;
    txtAciklama: TUniDBMemo;
    txtCihaz: TUniDBLookupComboBox;
    txtKategori: TUniDBLookupComboBox;
    txtEserAdi: TUniDBEdit;
    qCihazlar: TUniQuery;
    dsCihazlar: TDataSource;
    qKategoriler: TUniQuery;
    dsKategoriler: TDataSource;
    Yukle: TUniFileUpload;
    procedure UniFrameCreate(Sender: TObject);
    procedure silConfirm(Sender: TObject);
    procedure btnKapatClick(Sender: TObject);
    procedure btnKaydetClick(Sender: TObject);
    procedure btnSilClick(Sender: TObject);
    procedure btnVazgecClick(Sender: TObject);
    procedure btnYeniClick(Sender: TObject);
    procedure dsDosyaStateChange(Sender: TObject);
    procedure iptalConfirm(Sender: TObject);
    procedure UniFrameAjaxEvent(Sender: TComponent; EventName: string;
      Params: TUniStrings);
    procedure txtCihazEnter(Sender: TObject);
    procedure txtKategoriEnter(Sender: TObject);
    procedure txtKategoriKeyDown(Sender: TObject; var Key: Word;
      Shift: TShiftState);
    procedure txtCihazKeyDown(Sender: TObject; var Key: Word;
      Shift: TShiftState);
    procedure txtCihazTriggerEvent(Sender: TUniCustomComboBox;
      AButtonId: Integer);
    procedure txtKategoriTriggerEvent(Sender: TUniCustomComboBox;
      AButtonId: Integer);
    procedure txtDosyaAdiTriggerEvent(Sender: TUniFormControl;
      AButtonId: Integer);
    procedure YukleCompleted(Sender: TObject; AStream: TFileStream);
  private
    DOS_ID: integer;
    FTempFilePath: string;
    procedure DugmeleriAyarla;
    function GenerateGuid: string;
    { Private declarations }
  public
    { Public declarations }
    PDosyalarForm: TDosyalarForm;
  end;

implementation

{$R *.dfm}


uses ServerModule, MainModule, Utils, Cihazlar, Kategoriler;


procedure TDosyaForm.btnKapatClick(Sender: TObject);
begin
  try
    if qDosya.State in dsEditModes then
      iptal.Show
    else
    begin
      if PDosyalarForm<>nil then
      begin
        UniMainModule.DataSetRefresh(PDosyalarForm.qDosyalar, 'DOS_ID', qDosya.FieldByName('DOS_ID').AsInteger);
        UniMainModule.Focus(PDosyalarForm.txtCihaz);
      end;
      UniMainModule.FrameKapat(Self);
    end;
  except on E: Exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

function TDosyaForm.GenerateGuid: string;
var
  s: string;
begin
  s := StringReplace(TGUID.NewGuid.ToString, '{', '', [rfReplaceAll]);
  s := StringReplace(s, '}', '', [rfReplaceAll]);
  s := StringReplace(s, '-', '', [rfReplaceAll]);
  Result := s;
end;

procedure TDosyaForm.btnKaydetClick(Sender: TObject);
begin
  try
    if qDosya.State in dsEditModes then
    begin
      if Trim(qDosya.FieldByName('DOS_KAT_ID').AsString)='' then
      begin
        UniMainModule.Notification('', 'Kategori seçimi yapýnýz', 1);
        UniMainModule.Focus(txtKategori);
        exit;
      end;
      if Trim(qDosya.FieldByName('DOS_ESER_ADI').AsString)='' then
      begin
        UniMainModule.Notification('', 'Eser adýný giriniz', 1);
        UniMainModule.Focus(txtEserAdi);
        exit;
      end;
      if Trim(qDosya.FieldByName('DOS_DOSYA_ADI').AsString)='' then
      begin
        UniMainModule.Notification('', 'Yüklemek istediđiniz dosya seçimini yapýnýz', 1);
        UniMainModule.Focus(txtDosyaAdi);
        exit;
      end;
      qDosya.Post;
      CopyFile(PChar('files\temp\' + txtDosyaAdi.Text), PChar('files\docs\kategori\' + qKategoriler.FieldByName('KAT_KLASOR').AsString + '\' + txtDosyaAdi.Text), false);
      qDosya.ParamByName('DOS_ID').AsInteger := qDosya.FieldByName('DOS_ID').AsInteger;
      UniMainModule.Notification('', 'Ýţlem Tamamlandý', 3);
      UniMainModule.Focus(txtCihaz);
    end;
  except on E: Exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TDosyaForm.btnSilClick(Sender: TObject);
begin
  try
    sil.Show;
  except on E: Exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TDosyaForm.btnVazgecClick(Sender: TObject);
begin
  try
    if qDosya.State in dsEditModes then
    begin
      qDosya.Cancel;
      if not qDosya.FieldByName('DOS_ID').IsNull then
      begin
        qDosya.ParamByName('DOS_ID').AsInteger := qDosya.FieldByName('DOS_ID').AsInteger;
        UniMainModule.Focus(txtCihaz);
      end
      else
      begin
        if PDosyalarForm<>nil then
        begin
          UniMainModule.DataSetRefresh(PDosyalarForm.qDosyalar, 'DOS_ID', qDosya.FieldByName('DOS_ID').AsInteger);
          UniMainModule.Focus(PDosyalarForm.txtCihaz);
        end;
        UniMainModule.FrameKapat(Self);
      end;
    end;
  except on E: Exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TDosyaForm.btnYeniClick(Sender: TObject);
begin
  try
    if qDosya.State=dsBrowse then
    begin
      qDosya.Append;
      UniMainModule.Focus(txtCihaz);
    end;
  except on E: Exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TDosyaForm.dsDosyaStateChange(Sender: TObject);
begin
  DugmeleriAyarla;
end;

procedure TDosyaForm.silConfirm(Sender: TObject);
begin
  try
    qDosya.Delete;
    if PDosyalarForm<>nil then
    begin
      UniMainModule.DataSetRefresh(PDosyalarForm.qDosyalar, 'DOS_ID', qDosya.FieldByName('DOS_ID').AsInteger);
      UniMainModule.Focus(PDosyalarForm.txtCihaz);
    end;
    UniMainModule.Notification('', 'Kayýt Silindi', 3);
    UniMainModule.FrameKapat(Self);
  except on e:exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TDosyaForm.txtCihazEnter(Sender: TObject);
begin
  qCihazlar.DisableControls;
  try
    qCihazlar.Close;
    qCihazlar.Open;
    UniSession.Synchronize;
  finally
    qCihazlar.EnableControls;
  end;
end;

procedure TDosyaForm.txtCihazKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  if Key = VK_F4 then
    txtCihazTriggerEvent(txtCihaz, 1);
end;

procedure TDosyaForm.txtCihazTriggerEvent(Sender: TUniCustomComboBox;
  AButtonId: Integer);
var
  I: Integer;
  T: TUniTabSheet;
  F: TCihazlarForm;
begin
  if AButtonId=1 then
  begin
    try
      if isFrameOpenedInTab('TCihazlarForm', TUniTabSheet(Self.Parent)) then exit;
      T := TUniTabSheet(Self.Parent);
      T.Caption := T.Caption + ' > Cihazlar';

      for I := 0 to T.ControlCount-1 do
        T.Controls[I].Visible := False;

      UniMainModule.Tmp_Form_Sec := 1;
      F := TCihazlarForm.Create(T);
      F.UniPanel2.Caption :=  'Cihazlar';
      F.PDosyaForm := Self;
      F.Align := alClient;
      F.Parent := T;
      F.Show;
    except on E: Exception do
      UniMainModule.Notification('', HataMesaj(e.Message), 2);
    end;
  end;

end;

procedure TDosyaForm.txtDosyaAdiTriggerEvent(Sender: TUniFormControl;
  AButtonId: Integer);
begin
  Yukle.Execute;
end;

procedure TDosyaForm.txtKategoriEnter(Sender: TObject);
begin
  qKategoriler.DisableControls;
  try
    qKategoriler.Close;
    qKategoriler.Open;
    UniSession.Synchronize;
  finally
    qKategoriler.EnableControls;
  end;
end;

procedure TDosyaForm.txtKategoriKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  if Key = VK_F4 then
    txtKategoriTriggerEvent(txtKategori, 1);
end;

procedure TDosyaForm.txtKategoriTriggerEvent(Sender: TUniCustomComboBox;
  AButtonId: Integer);
var
  I: Integer;
  T: TUniTabSheet;
  F: TKategorilerForm;
begin
  if AButtonId=1 then
  begin
    try
      if isFrameOpenedInTab('TKategorilerForm', TUniTabSheet(Self.Parent)) then exit;
      T := TUniTabSheet(Self.Parent);
      T.Caption := T.Caption + ' > Kategoriler';

      for I := 0 to T.ControlCount-1 do
        T.Controls[I].Visible := False;

      UniMainModule.Tmp_Form_Sec := 1;
      F := TKategorilerForm.Create(T);
      F.UniPanel2.Caption :=  'Kategoriler';
      F.PDosyaForm := Self;
      F.Align := alClient;
      F.Parent := T;
      F.Show;
    except on E: Exception do
      UniMainModule.Notification('', HataMesaj(e.Message), 2);
    end;
  end;

end;

procedure TDosyaForm.UniFrameAjaxEvent(Sender: TComponent; EventName: string;
  Params: TUniStrings);
begin
  if EventName = 'esc_pressed' then btnKapatClick(Sender);
end;

procedure TDosyaForm.UniFrameCreate(Sender: TObject);
begin
  self.ClientEvents.ExtEvents.Values['afterrender'] := 'function afterrender(sender, eOpts)' +
         '{' +
         '   sender.el.on("keydown", function(e){' +
         '   if (e.getKey() == Ext.EventObject.ESC) {' +
         '      ajaxRequest(sender, "esc_pressed", []);' +
         '   }' +
         '   });' +
         '}';

  UniMainModule.ButtonMask([btnKaydet, btnVazgec, btnYeni, btnSil, btnKapat]);
  UniMainModule.SetFocusBlur(TUniFrame(Self));

  DOS_ID := UniMainModule.Tmp_ID;
  UniMainModule.Tmp_ID := -1;

  try
    if qCihazlar.Active then
      qCihazlar.Close;
    if qKategoriler.Active then
      qKategoriler.Close;
    if qDosya.Active then
      qDosya.Close;

    qCihazlar.Open;
    qKategoriler.Open;

    qDosya.ParamByName('DOS_ID').AsInteger := DOS_ID;
    qDosya.Open;

    if DOS_ID=0 then
    begin
      qDosya.Append;
    end;

    UniMainModule.Focus(txtCihaz);

  except on e: exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TDosyaForm.YukleCompleted(Sender: TObject; AStream: TFileStream);
begin
  if qDosya.State in dsEditModes then
  begin
    qDosya.FieldByName('DOS_DOSYA_ADI').AsString := Yukle.FileName;
  end;
end;

procedure TDosyaForm.DugmeleriAyarla;
begin
  try
    btnKaydet.Visible     := qDosya.State in dsEditModes;
    btnVazgec.Visible     := btnKaydet.Visible;
    btnYeni.Visible       := not btnKaydet.Visible;
    btnSil.Visible        := not btnKaydet.Visible;
  except on E: Exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

procedure TDosyaForm.iptalConfirm(Sender: TObject);
begin
  try
    qDosya.Cancel;
    if PDosyalarForm<>nil then
    begin
      UniMainModule.DataSetRefresh(PDosyalarForm.qDosyalar, 'DOS_ID', qDosya.FieldByName('DOS_ID').AsInteger);
      UniMainModule.Focus(PDosyalarForm.txtCihaz);
    end;
    UniMainModule.FrameKapat(Self)
  except on E: Exception do
    UniMainModule.Notification('', HataMesaj(e.Message), 2);
  end;
end;

end.
